// School Management System - Prisma Schema
// Note: Using SQLite (compatible design with PostgreSQL concepts)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ AUTH & USERS ============

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  role         String   @default("student") // super_admin, admin, teacher, student, finance, library
  avatar       String?
  phone        String?
  address      String?
  active       Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  student      Student?
  teacher      Teacher?
  financeStaff FinanceStaff?
  librarian    Librarian?
  sentMessages ContactMessage[] @relation("MessageSender")
  notifications Notification[]
  submissions  AssignmentSubmission[]
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires   DateTime
  createdAt DateTime @default(now())
}

// ============ ACADEMIC CORE ============

model Grade {
  id              String   @id @default(cuid())
  name            String   @unique // e.g. "Grade 1", "Grade 9", "Grade 12"
  code            String?  // e.g. "G9", "G10"
  level           Int      // numeric level for ordering
  educationLevel  String   @default("secondary") // primary, secondary, high_school
  description     String?
  status          String   @default("active")
  createdAt       DateTime @default(now())

  students        Student[]
  subjects        Subject[]
  sections        Section[]
  teacherAssignments TeacherAssignment[]
  timetables      Timetable[]
  exams           Exam[]
}

model Section {
  id              String   @id @default(cuid())
  name            String   // e.g. "A", "B", "C"
  gradeId         String
  grade           Grade    @relation(fields: [gradeId], references: [id])
  capacity        Int      @default(40)
  roomNumber      String?
  classTeacherId  String?  // Teacher ID who is the class teacher
  status          String   @default("active")
  createdAt       DateTime @default(now())

  students        Student[]
  teacherAssignments TeacherAssignment[]
  timetables      Timetable[]
}

model Subject {
  id              String   @id @default(cuid())
  name            String   // e.g. "Mathematics", "English"
  code            String   @unique
  gradeId         String?
  grade           Grade?   @relation(fields: [gradeId], references: [id])
  creditHours     Int      @default(1)
  passingMarks    Float    @default(50)
  totalMarks      Float    @default(100)
  status          String   @default("active")
  createdAt       DateTime @default(now())

  marks           Mark[]
  assignments     Assignment[]
  teacherAssignments TeacherAssignment[]
  curricula       Curriculum[]
  lessonPlans     LessonPlan[]
  timetables      Timetable[]
  exams           Exam[]
}

model AcademicYear {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "2026-2027"
  startDate   DateTime
  endDate     DateTime
  isCurrent   Boolean  @default(false)
  status      String   @default("active")
  createdAt   DateTime @default(now())

  semesters   Semester[]
  teacherAssignments TeacherAssignment[]
  curricula   Curriculum[]
  exams       Exam[]
}

model Semester {
  id              String   @id @default(cuid())
  academicYearId  String
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])
  name            String   // e.g. "Semester 1", "Term 1"
  startDate       DateTime
  endDate         DateTime
  status          String   @default("active")
  createdAt       DateTime @default(now())
}

// Enhanced TeacherAssignment with more fields
model TeacherAssignment {
  id              String   @id @default(cuid())
  teacherId       String
  teacher         Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  gradeId         String
  grade           Grade    @relation(fields: [gradeId], references: [id])
  sectionId       String?
  section         Section? @relation(fields: [sectionId], references: [id])
  subjectId       String
  subject         Subject  @relation(fields: [subjectId], references: [id])
  academicYearId  String?
  academicYear    AcademicYear? @relation(fields: [academicYearId], references: [id])
  academicYearName String? // e.g. "2026-2027" (for backward compat)
  campus          String?
  weeklyPeriods   Int      @default(0)
  room            String?
  status          String   @default("active") // active, inactive
  createdAt       DateTime @default(now())

  @@unique([teacherId, gradeId, sectionId, subjectId])
}

model Curriculum {
  id              String   @id @default(cuid())
  academicYearId  String?
  academicYear    AcademicYear? @relation(fields: [academicYearId], references: [id])
  subjectId       String
  subject         Subject  @relation(fields: [subjectId], references: [id])
  title           String
  description     String?
  topics          String?  // JSON array of topics
  objectives      String?
  createdAt       DateTime @default(now())
}

model LessonPlan {
  id              String   @id @default(cuid())
  subjectId       String
  subject         Subject  @relation(fields: [subjectId], references: [id])
  teacherId       String?
  teacher         Teacher? @relation(fields: [teacherId], references: [id])
  title           String
  description     String?
  content         String?
  date            DateTime?
  duration        Int?     // minutes
  fileUrl         String?
  createdAt       DateTime @default(now())
}

model Timetable {
  id              String   @id @default(cuid())
  gradeId         String
  grade           Grade    @relation(fields: [gradeId], references: [id])
  sectionId       String?
  section         Section? @relation(fields: [sectionId], references: [id])
  subjectId       String
  subject         Subject  @relation(fields: [subjectId], references: [id])
  teacherId       String?
  teacher         Teacher? @relation(fields: [teacherId], references: [id])
  dayOfWeek       String   // Monday, Tuesday, etc.
  startTime       String   // e.g. "08:00"
  endTime         String   // e.g. "08:45"
  room            String?
  academicYear    String?
  createdAt       DateTime @default(now())
}

model ExamType {
  id              String   @id @default(cuid())
  name            String   @unique // e.g. "Midterm", "Final", "Quiz"
  description     String?
  totalMarks      Float    @default(100)
  weight          Float    @default(100) // percentage weight in final grade
  createdAt       DateTime @default(now())

  exams           Exam[]
}

model Exam {
  id              String   @id @default(cuid())
  examTypeId      String
  examType        ExamType @relation(fields: [examTypeId], references: [id])
  academicYearId  String?
  academicYear    AcademicYear? @relation(fields: [academicYearId], references: [id])
  name            String
  gradeId         String?
  grade           Grade?  @relation(fields: [gradeId], references: [id])
  subjectId       String?
  subject         Subject? @relation(fields: [subjectId], references: [id])
  examDate        DateTime
  totalMarks      Float    @default(100)
  passingMarks    Float    @default(50)
  status          String   @default("scheduled") // scheduled, ongoing, completed
  createdAt       DateTime @default(now())
}

model GradingSystem {
  id              String   @id @default(cuid())
  name            String   @unique // e.g. "Standard Grading", "GPA"
  minPercentage   Float
  maxPercentage   Float
  grade           String   // e.g. "A+", "A", "B+"
  gradePoint      Float    @default(0)
  description     String?
  createdAt       DateTime @default(now())
}

model Holiday {
  id              String   @id @default(cuid())
  name            String
  date            DateTime
  type            String   @default("holiday") // holiday, event, exam
  description     String?
  createdAt       DateTime @default(now())
}

model Student {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  studentId       String   @unique // school student ID e.g. STU-2024-001
  firstName       String
  lastName        String
  gender          String   @default("male") // male, female
  dateOfBirth     DateTime?
  bloodGroup      String?
  nationalId      String?
  gradeId         String?
  grade           Grade?   @relation(fields: [gradeId], references: [id])
  sectionId       String?
  section         Section? @relation(fields: [sectionId], references: [id])
  guardianName    String?
  guardianPhone   String?
  guardianEmail   String?
  address         String?
  enrollmentDate  DateTime @default(now())
  status          String   @default("active") // active, graduated, suspended, transferred
  photoUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  marks           Mark[]
  attendance      Attendance[]
  submissions     AssignmentSubmission[]
  transactions    FinanceTransaction[]
  libraryLoans    LibraryLoan[]
  promotions      Promotion[]
}

model Teacher {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  teacherId    String   @unique // e.g. TCH-2024-001
  firstName    String
  lastName     String
  gender       String   @default("male")
  dateOfBirth  DateTime?
  qualification String?
  specialization String?
  experience    Int      @default(0) // years
  phone        String?
  address      String?
  joinDate     DateTime @default(now())
  salary       Float    @default(0)
  status       String   @default("active") // active, inactive, locked
  photoUrl     String?
  // Assignment scope - teacher can only access assigned academic year/grade/section/subjects
  academicYear String?  // e.g. "2026-2027"
  campus       String?  // school/campus name
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  marks        Mark[]
  assignments  Assignment[]
  attendance   Attendance[]
  teacherAssignments TeacherAssignment[]
  lessonPlans  LessonPlan[]
  timetables   Timetable[]
}

// ============ ACADEMIC RECORDS ============

model Mark {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])
  teacherId  String?
  teacher    Teacher? @relation(fields: [teacherId], references: [id])
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id])
  term       String   @default("Term 1") // Term 1, Term 2, Term 3
  assessmentType String @default("exam") // exam, quiz, assignment, project
  score      Float
  totalScore Float    @default(100)
  grade      String?  // A+, A, B+, B, C+, C, D, F
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Attendance {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])
  teacherId  String?
  teacher    Teacher? @relation(fields: [teacherId], references: [id])
  date       DateTime
  status     String   @default("present") // present, absent, late, excused
  remarks    String?
  createdAt  DateTime @default(now())
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  dueDate     DateTime
  maxScore    Float    @default(100)
  status      String   @default("active") // active, closed
  createdAt   DateTime @default(now())

  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String   @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  submittedById String?
  submittedBy  User?    @relation(fields: [submittedById], references: [id])
  content      String
  fileUrl      String?
  submittedAt  DateTime @default(now())
  score        Float?
  feedback     String?
  status       String   @default("submitted") // submitted, graded, returned
}

model Promotion {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])
  fromGrade  String
  toGrade    String
  academicYear String
  promoted   Boolean  @default(true)
  remarks    String?
  createdAt  DateTime @default(now())
}

model ReportCard {
  id         String   @id @default(cuid())
  studentId  String
  term       String
  academicYear String
  totalScore Float?
  average    Float?
  rank       Int?
  remarks    String?
  pdfUrl     String?
  createdAt  DateTime @default(now())
}

model Rank {
  id         String   @id @default(cuid())
  studentId  String
  term       String
  academicYear String
  rank       Int
  totalScore Float
  average    Float
  createdAt  DateTime @default(now())
}

// ============ FINANCE ============

model FinanceStaff {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  staffId   String   @unique
  firstName String
  lastName  String
  phone     String?
  createdAt DateTime @default(now())
}

model FinanceTransaction {
  id          String   @id @default(cuid())
  transactionId String @unique // e.g. TXN-2024-001
  studentId   String?
  student     Student? @relation(fields: [studentId], references: [id])
  type        String   // fee_payment, salary, expense, income, fine
  category    String   @default("tuition") // tuition, transport, library, exam, other
  amount      Float
  paymentMethod String @default("cash") // cash, bank, telebirr, cbe, dashen, awash, abyssinia
  bankReference String?
  description String?
  status      String   @default("completed") // pending, completed, failed, refunded
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeeStructure {
  id         String   @id @default(cuid())
  name       String
  gradeId    String?
  amount     Float
  category   String   @default("tuition")
  academicYear String
  term       String?
  createdAt  DateTime @default(now())
}

// ============ LIBRARY ============

model Librarian {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  staffId   String   @unique
  firstName String
  lastName  String
  phone     String?
  createdAt DateTime @default(now())
}

model Book {
  id         String   @id @default(cuid())
  bookId     String   @unique // e.g. BK-001
  title      String
  author     String
  isbn       String?
  category   String   @default("general")
  publisher  String?
  edition    String?
  year       Int?
  totalCopies Int     @default(1)
  availableCopies Int @default(1)
  shelfLocation String?
  description String?
  coverUrl   String?
  status     String   @default("available") // available, borrowed, lost, damaged
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  loans      LibraryLoan[]
}

model LibraryLoan {
  id         String   @id @default(cuid())
  bookId     String
  book       Book     @relation(fields: [bookId], references: [id])
  studentId  String?
  student    Student? @relation(fields: [studentId], references: [id])
  borrowerName String
  borrowerType String @default("student") // student, teacher, staff
  borrowDate DateTime @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     String   @default("borrowed") // borrowed, returned, overdue
  fine       Float    @default(0)
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============ HUMAN RESOURCE ============

model HRStaff {
  id           String   @id @default(cuid())
  staffId      String   @unique
  firstName    String
  lastName     String
  gender       String   @default("male")
  department   String   @default("academic")
  position     String
  phone        String?
  email        String?
  salary       Float    @default(0)
  joinDate     DateTime @default(now())
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============ ID CARDS & CERTIFICATES ============

model IDCard {
  id         String   @id @default(cuid())
  personId   String
  personType String   @default("student") // student, teacher, staff
  personName String
  cardNumber String   @unique
  issuedDate DateTime @default(now())
  expiryDate DateTime?
  status     String   @default("active")
  createdAt  DateTime @default(now())
}

model Certificate {
  id         String   @id @default(cuid())
  studentId  String?
  studentName String
  certificateType String @default("completion") // completion, achievement, transfer, graduation
  title      String
  description String?
  issuedDate DateTime @default(now())
  certificateNumber String @unique
  signedBy   String?
  createdAt  DateTime @default(now())
}

// ============ CMS & WEBSITE ============

model CMSPage {
  id        String   @id @default(cuid())
  slug      String   @unique // home, about, academy, teachers, students, contact, media
  title     String
  content   String   // rich text / markdown content (legacy)
  data      String?  // JSON string for structured page content (all editable sections)
  bannerImage String?
  metaDescription String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique // logo, favicon, header_text, footer_text, seo_title, seo_description, seo_keywords
  value     String
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String   @unique // facebook, twitter, instagram, youtube, linkedin, telegram
  url       String
  icon      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model MediaItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   // photo, video
  url         String
  thumbnailUrl String?
  category    String   @default("general") // event, sports, graduation, classroom, general
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model RegistrationApplication {
  id            String   @id @default(cuid())
  applicationId String   @unique // APP-2026-001
  trackingNumber String  @unique // TRK-2026-XXXXXX
  admissionNumber String? // ADM-2026-XXX (assigned on enroll)

  // Step 1: Student Information
  firstName     String
  lastName      String
  grandFatherName String?
  gender        String   @default("male") // male, female
  program       String?  // Regular Program, Night Program
  field         String?  // Natural Science, Social Science
  mediaOfInstruction String? // Afaan Oromoo, Afaan Amharaa
  dateOfBirth   DateTime?
  age           Int?
  nationalId    String?  // FAN/FCN Number
  studentPhoto  String?  // URL

  // Step 2: Academic Background
  applyForGrade String?  // Grade 9, 10, 11, 12
  lastGradeCompleted String?
  gradeAverage  String?  // e.g. "75.5%"
  lastSchoolAttended String?
  registrationCondition String? // New Student, Old Student

  // Step 3: Guardian Information
  guardianName  String
  guardianRelationship String? // Father, Mother, Sister, Brother, Guardian
  guardianPhone String
  guardianEmail String?
  guardianAddress String?

  // Step 4: Documents
  certificateFrontUrl  String?
  certificateBackUrl   String?
  studentIdFrontUrl    String?
  parentPhotoUrl       String?
  parentIdUrl          String? // Woreda or Fayda Number
  clearanceUrl         String?

  // Step 5: Payment
  paymentMethod    String? // telebirr, cbe
  payCode          String? // generated by admin
  paymentAmount    Float?  // set by admin
  paymentReceiptUrl String?

  // Workflow
  status        String   @default("submitted") // submitted, under_review, approved, rejected, enrolled
  submittedAt   DateTime @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?
  reviewedByName String?
  remarks       String?
  enrollRemarks String?
  enrolledAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("new") // new, read, replied, closed
  repliedById String?
  repliedBy User?    @relation("MessageSender", fields: [repliedById], references: [id])
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model Event {
  id         String   @id @default(cuid())
  title      String
  description String?
  date       DateTime
  location   String?
  type       String   @default("event") // event, holiday, exam, meeting
  createdAt  DateTime @default(now())
}
